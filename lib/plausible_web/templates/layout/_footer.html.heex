                    Dashboard guide
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/excluding"
                    class="text-base text-gray-300 leading-6 hover:text-white"
                  >
                    Exclude traffic
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/filters-segments"
                    class="text-base text-gray-300 leading-6 hover:text-white"
                  >
                    Segmentation
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/compare-stats"
                    class="text-base text-gray-300 leading-6 hover:text-white"
                  >
                    Compare stats
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/google-search-console-integration"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
                    Search console
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/dashboard-faq"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
                    FAQ
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/bot-traffic-filtering"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
                    Bot traffic filtering
                  </a>
                </li>
              </ul>
            </div>
          </div>
          <div class="md:grid md:grid-cols-2 md:gap-8 print:hidden">
            <div>
              <h4 class="text-sm leading-5 font-semibold tracking-wider text-gray-400 uppercase">
                Advanced
              </h4>
              <ul class="mt-4">
                <li>
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/proxy/introduction"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
                    Bypass ad blockers
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/custom-event-goals"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
                    Custom events
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/ecommerce-revenue-tracking"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
                    Revenue attribution
                  </a>
                </li>
                <li class="mt-4">
                  <a
                    rel="noreferrer"
                    href="https://plausible.io/docs/custom-props/introduction"
                    class="text-base leading-6 text-gray-300 hover:text-white"
                  >
