ARG ALPINE_VERSION=3.22.2

FROM hexpm/elixir:1.19.4-erlang-27.3.4.6-alpine-${ALPINE_VERSION}

ENV MIX_ENV=dev
ENV NODE_ENV=development

# inotify-tools: required by phoenix_live_reload (file_system) for hot reload on Linux
# nodejs-current: matches the version installed in the production Dockerfile
RUN apk add --no-cache \
    git nodejs-current npm python3 \
    ca-certificates wget gnupg make gcc libc-dev inotify-tools

WORKDIR /app

RUN mix local.hex --force && mix local.rebar --force

# ── Step 1: package manifests only (cached layer) ─────────────────────────
# config/ is required so mix deps.get can resolve environment-specific deps
COPY mix.exs mix.lock ./
COPY config ./config

RUN mix deps.get && mix deps.compile

COPY assets/package.json assets/package-lock.json ./assets/
COPY tracker/package.json tracker/package-lock.json ./tracker/

# npm install (not npm ci) — packages are compiled for Linux/x64 inside the image
RUN npm install --prefix ./assets && \
    npm install --prefix ./tracker && \
    mix assets.setup

# ── Step 2: source files last ─────────────────────────────────────────────
# At runtime these are shadowed by the bind mount in docker-compose.dev.yml,
# enabling hot reloading. This COPY is a fallback for non-compose usage.
COPY . .

EXPOSE 8000
CMD ["mix", "phx.server"]
