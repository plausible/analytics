node_modules/
.env*.local

# Scan output — regenerated by `deepsec scan` / `process`. INFO.md
# and SETUP.md (manually edited) stay tracked.
data/*/files/
data/*/runs/
data/*/reports/
data/*/debug/
data/*/project.json
# tech.json embeds an absolute `rootPath` of whoever last scanned; it is
# auto-regenerated by scan/process (only `.tags` is consumed), so keep it
# out of git to avoid leaking local paths.
data/*/tech.json
